# Copy to .env.local and fill in. .env* is gitignored.
ANTHROPIC_API_KEY=sk-ant-...

# Workhorse model for the pipeline (signal extractor, reasoner, verifier).
ANTHROPIC_MODEL=claude-sonnet-5

# Hard timeout (ms) for the verifier's in-context grounding step.
# On timeout the verifier degrades to "unverified" chips rather than hanging the demo.
VERIFIER_TIMEOUT_MS=8000
